# ── Choose one LLM mode ───────────────────────────────────────────────────────
# LLM_MODE=anthropic_api_key
# LLM_MODE=openai_api_key
# LLM_MODE=openrouter_api_key
# LLM_MODE=openclaw_api          (no tool calling — wiki ops won't work)
# LLM_MODE=openai_codex_oauth    (no tool calling — wiki ops won't work)
LLM_MODE=anthropic_api_key

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-…
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-…
OPENAI_MODEL=gpt-4o

# ── OpenAI Codex OAuth ────────────────────────────────────────────────────────
OPENAI_OAUTH_TOKEN=eyJhbGci…
OPENAI_CODEX_MODEL=gpt-5.5

# ── OpenClaw ──────────────────────────────────────────────────────────────────
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_API_KEY=your-key
OPENCLAW_MODEL=openclaw/default
OPENCLAW_UPSTREAM_MODEL=openai-codex/gpt-5.5

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-…
OPENROUTER_MODEL=anthropic/claude-sonnet-4
